{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "measurement-route": {
        "ClusterId": "measurement-cluster",
        "Match": {
          "Path": "/api/v1/quantities/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5086"
          }
        }
      },
      "measurement-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5024"
          }
        }
      }
    }
  }
}
